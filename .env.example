CLIENT_PORT=3000
SERVER_PORT=5000

# Replace YOUR_NAS_IP_OR_DOMAIN with the address your browser will use to reach the NAS.
CLIENT_ORIGIN=http://YOUR_NAS_IP_OR_DOMAIN:3000
SERVER_URL=http://YOUR_NAS_IP_OR_DOMAIN:5000
NEXT_PUBLIC_SERVER_URL=http://YOUR_NAS_IP_OR_DOMAIN:5000
NEXT_PUBLIC_API_URL=http://YOUR_NAS_IP_OR_DOMAIN:5000

# Must be 32 characters or longer.
NEXT_PUBLIC_ENCRYPTION_KEY=change-this-to-a-32-character-secret

# Optional. Leave empty if you do not use AI features.
GEMINI_API_KEY=
